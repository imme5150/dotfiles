{
    "layer": "top",
    "position": "bottom",
    "modules-right": [
        "network",
        "tray",
        "bluetooth",
        "pulseaudio",
        "backlight",
        "battery",
        "hyprland/language",
        "custom/sleep",
        "custom/clock"
    ],
    "hyprland/workspaces": {
        "format": "{name} {icon}",
        "format-icons": {
            "default": "юо┤"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "custom/music": {
        "format": "яАБ {} ґ░ОЗ",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ title }}'",
        "on-click": "playerctl play-pause",
        "max-length": 50
    },
    "custom/clock": {
        "format": "{text}",
        "exec": "date +\"%-I:%M %p - %a %b %e\"",
        "interval": 1
    },
    "cpu": {
        "format": "{usage}% яЛЫ",
        "on-click": "kitty -e htop"
    },
    "memory": {
        "format": "{}% ю┐Е"
    },
    "backlight": {
        // "device": "intel_backlight",
        "format": "{icon}",
        "tooltip-format": "{percent}%",
        "format-icons": [
            "таБ",
            "таГ",
            "таЙ",
            "таЩ",
            "таС",
            "таЛ",
            "таЫ",
            "таУ",
            "таК",
            "таЪ"
        ]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 49,
            "critical": 40
        },
        "format": "{icon} {capacity}%",
        "format-charging": "тЪб {capacity}%",
        "format-plugged": "{capacity}%",
        "format-charged": "{capacity}%",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "яСж Muted",
        "format-icons": {
            "default": [
                "яАж",
                "яАз",
                "яАи "
            ]
        },
        "scroll-step": 5,
        "on-click": "pavucontrol-qt",
        "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} {signalStrength}%",
        "format-ethernet": "ґ░ИА",
        "format-linked": "яГБ",
        "format-disabled": "тЪа",
        "format-disconnected": "тЪа",
        "tooltip-format": "яЗл  {bandwidthDownBits}тЖУ {bandwidthUpBits}тЖС",
        "on-click": "kitty -e nmtui"
    },
    "bluetooth": {
        "format": "яКФ",
        "format-no-controller": "-",
        "format-connected": "яКФ {device_alias}",
        "format-connected-battery": "яКФ {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "kitty -e bluetui",
        "on-click-right": "exec bluedevil-wizard"
    },
    "hyprland/language": {
        "format": "{short} {variant}"
        // "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "hyprlock",
        "format": "яАг"
    },
    "custom/sleep": {
        "tooltip": false,
        "on-click": "exec systemctl suspend",
        "on-click-right": "exec ~/.config/hypr/scripts/power_menu.sh",
        "format": "тП╗"
    },
    "custom/browser": {
        "format": "яЙй",
        "on-click": "exec firefox",
        "tooltip-format": "Firefox"
    },
    "custom/terminal": {
        "format": "яДа ",
        "on-click": "exec kitty",
        "tooltip-format": "Terminal"
    },
    "custom/files": {
        "format": "ґ░ЙЛ",
        "on-click": "exec dolphin",
        "tooltip-format": "Files"
    },
    "custom/player": {
        "format": "ґ░ОЗ",
        "on-click": "exec spotify-launcher",
        "tooltip-format": "Spotify"
    },
    "custom/launcher": {
        "format": "яД╡",
        "on-click": "exec ~/.config/hypr/scripts/appLauncher.sh",
        "tooltip-format": "Launcher"
    }
}
